---
import { clients } from '../data/clients';
---

<section class="relative border-t border-ink bg-cream px-6 py-16 md:px-10 md:py-24">
  <div class="mx-auto max-w-[1400px]">
    <div class="mb-12 flex flex-col gap-4 md:mb-16 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="label text-ink/60">Клиенты</p>
        <h2 class="mt-3 font-display text-5xl leading-[1.2] md:text-7xl">
          Нам доверяют
        </h2>
      </div>
      <p class="max-w-md text-sm text-ink/70 md:text-base">
        От федеральных корпораций до профильных сообществ и культурных
        площадок. Каждому — своя оптика, свой ритм и свой результат.
      </p>
    </div>

    <ul class="divide-y divide-ink/20 border-y border-ink/20">
      {clients.map((client, i) => {
        const Tag = client.href ? 'a' : 'div';
        return (
        <li class="group relative">
          <Tag
            {...(client.href
              ? { href: client.href, target: '_blank', rel: 'noopener' }
              : {})}
            class="grid grid-cols-1 items-center gap-6 py-8 md:grid-cols-[260px_1fr_auto] md:gap-10 md:py-10"
          >
            <!-- logo mark: uniform box, logos scale inside with object-contain -->
            <div class="flex h-14 w-48 items-center md:h-16 md:w-56">
              {client.mark === 'gazprom' && (
                <img
                  src="/logos/gazprom.png"
                  alt="Газпром"
                  class="max-h-full max-w-full origin-left scale-[1.7] object-contain object-left"
                  loading="lazy"
                />
              )}
              {client.mark === 'dprofile' && (
                <img
                  src="/logos/dprofile.png"
                  alt="Dprofile"
                  class="max-h-full max-w-full object-contain object-left"
                  loading="lazy"
                />
              )}
              {client.mark === 'circus' && (
                <img
                  src="/logos/circus.png"
                  alt="Большой Санкт-Петербургский государственный цирк на Фонтанке"
                  class="max-h-full max-w-full object-contain object-left"
                  loading="lazy"
                />
              )}
              {client.mark === 'raketa' && (
                <img
                  src="/logos/raketa.png"
                  alt="Raketa"
                  class="max-h-full max-w-full object-contain object-left"
                  loading="lazy"
                />
              )}
            </div>

            <!-- description -->
            <p class="max-w-2xl text-base leading-relaxed text-ink/80 md:text-lg">
              {client.description}
            </p>

            <!-- index number + arrow -->
            <div class="flex items-center gap-4">
              <span class="label text-ink/40">
                № {String(i + 1).padStart(2, '0')}
              </span>
              <svg
                viewBox="0 0 24 24"
                class="h-5 w-5 text-ink/50 transition-all duration-300 group-hover:translate-x-1 group-hover:text-ink"
                aria-hidden="true"
              >
                <path
                  d="M5 12h14M13 5l7 7-7 7"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  fill="none"
                />
              </svg>
            </div>
          </div>

          </Tag>

          <!-- hover highlight bar -->
          <div class="pointer-events-none absolute inset-x-0 bottom-0 h-0 bg-lime/0 transition-all duration-300 group-hover:h-full group-hover:bg-lime/10"></div>
        </li>
      );
      })}
    </ul>

    <p class="mt-10 text-center text-sm text-ink/60 md:mt-12">
      И ещё десятки проектов. Полный список — по запросу.
    </p>
  </div>
</section>

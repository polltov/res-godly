---
import { site } from '../config/site';
const vimeoFullSrc = `https://player.vimeo.com/video/${site.showreelVimeoId}?autoplay=1&title=0&byline=0&portrait=0`;
---

<section class="relative overflow-hidden px-6 pt-14 pb-12 md:px-10 md:pt-20 md:pb-16">
  <div class="mx-auto grid max-w-[1400px] gap-10 md:grid-cols-12 md:items-start md:gap-12">
    <!-- Left: label + wordmark + description + CTAs -->
    <div class="md:col-span-7">
      <p class="label mb-10 md:mb-14">Видеопродакшн для бизнеса · СПб · с 2014</p>
      <h1 class="hero-letters relative text-[clamp(3rem,7.5vw,6.5rem)] leading-[1.2] text-ink">
        <span class="relative inline-block">
          <span class="relative z-10">RES</span>
          <!-- Signature curved bar through the letters (Ujjo-style) -->
          <svg
            viewBox="0 0 520 80"
            preserveAspectRatio="none"
            class="absolute left-[-4%] right-[-4%] top-[52%] z-20 h-[55%] w-[108%] -translate-y-1/2"
            aria-hidden="true"
          >
            <path
              d="M8 48 C 80 8, 180 76, 260 32 S 440 76, 512 28"
              fill="none"
              stroke="currentColor"
              stroke-width="14"
              stroke-linecap="round"
            />
          </svg>
        </span>
        <span class="block text-ink">.prod</span>
      </h1>
      <p class="mt-8 max-w-xl text-base text-ink/80 md:mt-10 md:text-lg">
        Бутиковая студия видеопроизводства. Рекламные и имиджевые ролики, съёмки
        мероприятий, прямые трансляции. От идеи до финального монтажа — измеримый
        результат для бизнеса.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <button type="button" data-lead-trigger class="btn-ink">Оставить заявку</button>
        <a href="#works" class="btn-outline">Посмотреть работы</a>
      </div>
    </div>

    <!-- Right: showreel card + metrics -->
    <div class="md:col-span-5">
      <div
        class="relative overflow-hidden rounded-[28px] border border-ink bg-lime p-6 md:p-8"
      >
        <p class="label mb-4 text-ink/70">Шоурил 2025</p>
        <h2 class="font-display text-3xl leading-[1.2] tracking-tight text-ink md:text-4xl">
          Конвертируем&nbsp;наш опыт&nbsp;в ваш&nbsp;результат.
        </h2>
        <div class="group relative mt-6 aspect-[16/10] overflow-hidden rounded-2xl border border-ink/90 bg-ink">
          <iframe
            src={`https://player.vimeo.com/video/${site.showreelVimeoId}?title=0&byline=0&portrait=0&background=1&muted=1&loop=1&autoplay=1`}
            class="absolute inset-0 h-full w-full"
            allow="autoplay; fullscreen"
            loading="lazy"
            title="RES prod showreel preview"
          ></iframe>
          <button
            type="button"
            data-showreel-play
            aria-label="Смотреть полный шоурил"
            class="absolute inset-0 flex items-center justify-center bg-ink/0 transition-colors duration-300 hover:bg-ink/35 focus:outline-none focus-visible:ring-2 focus-visible:ring-lime"
          >
            <span
              class="flex h-20 w-20 items-center justify-center rounded-full border border-ink bg-lime text-ink shadow-[4px_4px_0_rgba(10,10,10,0.9)] transition-transform duration-300 group-hover:scale-105 group-hover:-rotate-3 md:h-24 md:w-24"
            >
              <svg viewBox="0 0 24 24" class="ml-1 h-8 w-8 md:h-10 md:w-10" aria-hidden="true">
                <polygon points="6,4 20,12 6,20" fill="currentColor" />
              </svg>
            </span>
          </button>
        </div>
        <div class="mt-5 flex items-center justify-between gap-3">
          <button
            type="button"
            data-showreel-play
            class="label flex items-center gap-2 underline-offset-4 hover:underline"
          >
            <svg viewBox="0 0 24 24" class="h-4 w-4" aria-hidden="true">
              <polygon points="6,4 20,12 6,20" fill="currentColor" />
            </svg>
            Смотреть шоурил
          </button>
          <a href={site.telegram} target="_blank" rel="noopener" class="btn-ink">
            Написать
          </a>
        </div>
        <!-- decorative spark -->
        <svg
          viewBox="0 0 40 40"
          class="absolute right-6 top-6 h-8 w-8 text-ink/70"
          aria-hidden="true"
        >
          <path
            d="M20 2v12M20 26v12M2 20h12M26 20h12M7 7l8 8M25 25l8 8M33 7l-8 8M15 25l-8 8"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
          />
        </svg>
      </div>

      <!-- metric ticker under card -->
      <div class="mt-6 grid grid-cols-2 gap-3 text-center">
        <div class="card py-4">
          <p class="font-display text-2xl leading-none">10+</p>
          <p class="label mt-2 text-ink/70">лет опыта</p>
        </div>
        <div class="card py-4">
          <p class="font-display text-2xl leading-none">120+</p>
          <p class="label mt-2 text-ink/70">проектов</p>
        </div>
      </div>
    </div>
  </div>
</section>

<dialog
  id="showreel-dialog"
  class="showreel-modal w-[min(94vw,1100px)] rounded-[24px] border border-ink bg-ink p-0"
  aria-labelledby="showreel-title"
>
  <div class="relative">
    <div class="flex items-center justify-between gap-3 px-5 py-4 md:px-6 md:py-5">
      <div class="flex items-center gap-3 text-cream">
        <span class="label text-lime">Шоурил 2025</span>
        <span id="showreel-title" class="hidden text-sm text-cream/80 md:inline">RES.PROD</span>
      </div>
      <button
        type="button"
        data-showreel-close
        class="flex h-9 w-9 items-center justify-center rounded-full border border-cream/50 text-cream transition-colors hover:bg-cream hover:text-ink"
        aria-label="Закрыть"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4" aria-hidden="true">
          <path d="M6 6l12 12M18 6 6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none" />
        </svg>
      </button>
    </div>
    <div class="relative aspect-video w-full overflow-hidden bg-black">
      <iframe
        id="showreel-frame"
        src=""
        class="absolute inset-0 h-full w-full"
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen
        title="RES.PROD showreel"
      ></iframe>
    </div>
  </div>
</dialog>

<style is:global>
  dialog.showreel-modal {
    position: fixed;
    inset: 0;
    margin: auto;
    color: inherit;
    transform-origin: 50% 50%;
  }
  dialog.showreel-modal[open] {
    animation: showreelPop 320ms cubic-bezier(0.2, 0.85, 0.25, 1);
  }
  dialog.showreel-modal::backdrop {
    background: rgba(10, 10, 10, 0.85);
    backdrop-filter: blur(6px);
    animation: showreelFade 240ms ease-out;
  }
  @keyframes showreelPop {
    from { transform: scale(0.9); opacity: 0; }
    to   { transform: scale(1);   opacity: 1; }
  }
  @keyframes showreelFade {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    dialog.showreel-modal[open],
    dialog.showreel-modal::backdrop { animation: none; }
  }
</style>

<script is:inline define:vars={{ vimeoFullSrc }}>
  const dialog = document.getElementById('showreel-dialog');
  const frame = document.getElementById('showreel-frame');
  if (dialog && frame) {
    const open = () => {
      frame.src = vimeoFullSrc;
      dialog.showModal();
    };
    const close = () => {
      dialog.close();
      frame.src = '';
    };
    document.querySelectorAll('[data-showreel-play]').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        open();
      });
    });
    dialog.querySelector('[data-showreel-close]')?.addEventListener('click', close);
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) close();
    });
    dialog.addEventListener('close', () => { frame.src = ''; });
  }
</script>

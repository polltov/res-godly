---
import { site } from '../config/site';
const year = new Date().getFullYear();
---

<style is:global>
  .scroll-reveal-left,
  .scroll-reveal-right {
    display: inline-block;
    transform: translateY(110%);
    opacity: 0;
    transition: transform 1000ms cubic-bezier(0.2, 0.85, 0.25, 1), opacity 700ms ease-out;
    will-change: transform, opacity;
  }
  .scroll-reveal-right {
    transition-delay: 140ms;
  }
  .scroll-reveal-logo.is-visible .scroll-reveal-left,
  .scroll-reveal-logo.is-visible .scroll-reveal-right {
    transform: translateY(0);
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-reveal-left,
    .scroll-reveal-right {
      transform: none;
      opacity: 1;
      transition: none;
    }
  }
</style>

<script>
  const revealLogo = () => {
    const target = document.querySelector<HTMLElement>('.scroll-reveal-logo');
    if (!target) return;
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            target.classList.add('is-visible');
            io.disconnect();
          }
        });
      },
      { threshold: 0.35 }
    );
    io.observe(target);
  };
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', revealLogo);
  } else {
    revealLogo();
  }
</script>

<footer id="contacts" class="relative mt-24 overflow-hidden border-t border-ink">
  <!-- purple wave "lava" band with echo logotype -->
  <div class="relative bg-violet">
    <!-- top wave -->
    <svg
      viewBox="0 0 1400 120"
      preserveAspectRatio="none"
      class="absolute -top-px left-0 h-16 w-full text-cream md:h-24"
      aria-hidden="true"
    >
      <path
        d="M0,64 C200,24 360,108 560,64 C760,24 960,108 1160,60 C1280,36 1360,72 1400,56 L1400,0 L0,0 Z"
        fill="currentColor"
      />
    </svg>

    <div class="relative overflow-hidden px-6 pt-24 pb-10 md:px-10 md:pt-32">
      <p
        class="hero-letters scroll-reveal-logo whitespace-nowrap text-center text-[clamp(3rem,12vw,13rem)] leading-[0.82] text-ink"
      >
        <span class="scroll-reveal-left relative inline-block">
          res
          <svg
            viewBox="0 0 520 80"
            class="absolute left-[-4%] right-[-4%] top-[40%] w-[108%] -translate-y-1/2"
            aria-hidden="true"
          >
            <path
              d="M8 48 C 80 8, 180 76, 260 32 S 440 76, 512 28"
              fill="none"
              stroke="currentColor"
              stroke-width="9"
              stroke-linecap="round"
            />
          </svg>
        </span><span class="scroll-reveal-right">.prod</span>
      </p>
    </div>

    <!-- bottom wave back to cream -->
    <svg
      viewBox="0 0 1400 120"
      preserveAspectRatio="none"
      class="absolute -bottom-px left-0 h-16 w-full text-cream md:h-24"
      aria-hidden="true"
    >
      <path
        d="M0,56 C200,96 360,8 560,56 C760,96 960,8 1160,60 C1280,84 1360,48 1400,64 L1400,120 L0,120 Z"
        fill="currentColor"
      />
    </svg>
  </div>

  <!-- contacts block on cream -->
  <div class="relative bg-cream px-6 py-12 md:px-10 md:py-16">
    <div class="mx-auto grid max-w-[1400px] gap-10 md:grid-cols-12">
      <!-- column 1: cta -->
      <div class="md:col-span-5">
        <p class="label text-ink/60">Пора снимать</p>
        <h3 class="mt-3 font-display text-4xl leading-[1.25] md:text-5xl">
          Обсудим&nbsp;ваш проект?
        </h3>
        <div class="mt-6 flex flex-wrap gap-3">
          <button type="button" data-lead-trigger class="btn-ink">Оставить заявку</button>
          <a href={site.telegram} target="_blank" rel="noopener" class="btn-outline">
            Telegram
          </a>
          <a href={`mailto:${site.email}`} class="btn-outline">Email</a>
          <a href={site.vk} target="_blank" rel="noopener" class="btn-outline">VK</a>
        </div>
      </div>

      <!-- column 2: contacts -->
      <div class="md:col-span-4">
        <p class="label text-ink/60">Контакты</p>
        <ul class="mt-4 space-y-2 text-base md:text-lg">
          <li>
            <a class="underline-offset-4 hover:underline" href={`tel:${site.phone.replace(/[^\d+]/g, '')}`}>
              {site.phone}
            </a>
          </li>
          <li>
            <a class="underline-offset-4 hover:underline" href={`mailto:${site.email}`}>
              {site.email}
            </a>
          </li>
          <li>{site.city}</li>
        </ul>
        <a
          href={`${import.meta.env.BASE_URL}/privacy`.replace(/\/+/g, '/')}
          class="mt-5 inline-block text-sm text-ink/60 underline-offset-4 hover:text-ink hover:underline"
        >
          Политика конфиденциальности
        </a>
      </div>

      <!-- column 3: legal -->
      <div class="md:col-span-3">
        <p class="label text-ink/60">Реквизиты</p>
        <p class="mt-4 text-sm text-ink/80">{site.legalEntity}</p>
        <p class="mt-2 text-sm text-ink/60">© {year} {site.name}. Все права защищены.</p>
      </div>
    </div>
  </div>
</footer>

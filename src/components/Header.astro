---
import { site } from '../config/site';

const nav = [
  { label: 'Работы', href: '#works' },
  { label: 'Услуги', href: '#services' },
  { label: 'О студии', href: '#about' },
  { label: 'Контакты', href: '#contacts' },
];
---

<header class="sticky top-0 z-40 border-b border-ink/90 bg-cream/85 backdrop-blur-md">
  <div class="mx-auto flex max-w-[1400px] items-center justify-between gap-4 px-5 py-3 md:px-8 lg:gap-8 lg:py-4">
    <!-- Logo -->
    <a
      href={import.meta.env.BASE_URL}
      class="relative inline-block shrink-0 font-display text-[24px] leading-none tracking-tight text-ink md:text-[28px] lg:text-[32px]"
      aria-label="RES prod"
    >
      <span class="relative z-10">RES</span>
      <svg
        viewBox="0 0 520 80"
        class="pointer-events-none absolute left-[-6%] right-[-6%] top-[52%] z-20 w-[112%] -translate-y-1/2"
        aria-hidden="true"
      >
        <path
          d="M8 48 C 80 8, 180 76, 260 32 S 440 76, 512 28"
          fill="none"
          stroke="currentColor"
          stroke-width="9"
          stroke-linecap="round"
        />
      </svg>
    </a>

    <!-- Desktop nav (≥lg) -->
    <nav class="hidden items-center gap-7 lg:flex">
      {nav.map((item) => (
        <a
          href={item.href}
          class="label whitespace-nowrap text-ink/80 transition-colors hover:text-ink"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Right cluster -->
    <div class="flex items-center gap-3">
      <!-- Telegram button: full label on lg+, short on md, hidden below sm -->
      <a
        href={site.telegram}
        target="_blank"
        rel="noopener"
        class="btn-ink whitespace-nowrap px-4 py-2 text-xs tracking-[0.15em] md:px-6 md:py-3 md:text-sm"
      >
        <span class="hidden sm:inline">Telegram</span>
        <span class="sm:hidden">TG</span>
      </a>

      <!-- Mobile/tablet menu (<lg) -->
      <details class="relative lg:hidden">
        <summary
          class="flex h-10 w-10 cursor-pointer items-center justify-center rounded-full border border-ink/70 text-ink list-none [&::-webkit-details-marker]:hidden"
          aria-label="Открыть меню"
        >
          <svg viewBox="0 0 24 24" class="h-5 w-5" aria-hidden="true">
            <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none" />
          </svg>
        </summary>
        <nav class="absolute right-0 top-12 z-50 w-56 rounded-2xl border border-ink bg-cream p-2 shadow-xl">
          {nav.map((item) => (
            <a
              href={item.href}
              class="block rounded-xl px-4 py-3 text-sm text-ink hover:bg-ink hover:text-cream"
            >
              {item.label}
            </a>
          ))}
        </nav>
      </details>
    </div>
  </div>
</header>

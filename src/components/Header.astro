---
import { site } from '../config/site';

const navLeft = [
  { label: 'Работы', href: '#works' },
  { label: 'Услуги', href: '#services' },
];
const navRight = [
  { label: 'О студии', href: '#about' },
  { label: 'Контакты', href: '#contacts' },
];
---

<header class="sticky top-0 z-40 border-b border-ink/90 bg-cream/85 backdrop-blur-md">
  <div class="mx-auto grid max-w-[1400px] grid-cols-[1fr_auto_1fr] items-center gap-6 px-6 py-4 md:px-10">
    <nav class="flex items-center gap-6 md:gap-8">
      {navLeft.map((item) => (
        <a
          href={item.href}
          class="label text-ink/80 transition-colors hover:text-ink"
        >
          {item.label}
        </a>
      ))}
    </nav>
    <a href="/" class="flex items-center justify-center">
      <svg viewBox="0 0 44 44" class="h-9 w-9" aria-label="RES prod">
        <circle cx="22" cy="22" r="21" fill="none" stroke="currentColor" stroke-width="2" />
        <g transform="translate(22 22)" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round">
          <line x1="0" y1="-11" x2="0" y2="-6" />
          <line x1="0" y1="6" x2="0" y2="11" />
          <line x1="-11" y1="0" x2="-6" y2="0" />
          <line x1="6" y1="0" x2="11" y2="0" />
          <line x1="-7.8" y1="-7.8" x2="-4.2" y2="-4.2" />
          <line x1="4.2" y1="4.2" x2="7.8" y2="7.8" />
          <line x1="-7.8" y1="7.8" x2="-4.2" y2="4.2" />
          <line x1="4.2" y1="-4.2" x2="7.8" y2="-7.8" />
          <circle cx="0" cy="0" r="3" fill="currentColor" />
        </g>
      </svg>
    </a>
    <nav class="flex items-center justify-end gap-6 md:gap-8">
      {navRight.map((item) => (
        <a
          href={item.href}
          class="label text-ink/80 transition-colors hover:text-ink"
        >
          {item.label}
        </a>
      ))}
      <a
        href={site.telegram}
        target="_blank"
        rel="noopener"
        class="btn-ink hidden md:inline-flex"
      >
        Telegram
      </a>
    </nav>
  </div>
</header>

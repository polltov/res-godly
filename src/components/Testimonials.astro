---
import { testimonials } from '../data/testimonials';
---

<section class="relative px-6 py-16 md:px-10 md:py-24">
  <div class="mx-auto max-w-[1400px]">
    <div class="mb-10 flex items-end justify-between md:mb-14">
      <div>
        <p class="label text-ink/60">Отзывы</p>
        <h2 class="mt-3 font-display text-5xl leading-[0.95] md:text-7xl">
          Слово клиента
        </h2>
      </div>
      <svg viewBox="0 0 80 80" class="hidden h-16 w-16 text-ink md:block" aria-hidden="true">
        <path
          d="M10 45c0-18 10-30 28-32M42 45c0-18 10-30 28-32"
          fill="none"
          stroke="currentColor"
          stroke-width="3"
          stroke-linecap="round"
        />
        <path
          d="M10 45h20v25H10zM42 45h20v25H42z"
          fill="currentColor"
          stroke="currentColor"
          stroke-width="3"
        />
      </svg>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 md:gap-10">
      {testimonials.map((t, i) => (
        <figure class={`border-y border-ink py-8 md:py-10 ${i === 1 ? 'md:border-l md:border-r-0 md:pl-10' : ''}`}>
          <blockquote class="font-display text-2xl leading-[1.15] md:text-4xl">
            «{t.quote}»
          </blockquote>
          <figcaption class="label mt-6 text-ink/70">— {t.client}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

---
---

<div id="splash" class="splash" aria-hidden="true">
  <div class="splash-inner">
    <p class="splash-letters font-display">
      <span class="splash-res relative inline-block">
        res
        <svg
          viewBox="0 0 520 80"
          class="splash-bar"
          aria-hidden="true"
        >
          <path
            d="M8 48 C 80 8, 180 76, 260 32 S 440 76, 512 28"
            fill="none"
            stroke="currentColor"
            stroke-width="9"
            stroke-linecap="round"
          />
        </svg>
      </span><span class="splash-prod">.prod</span>
    </p>
    <div class="splash-track" aria-hidden="true">
      <div class="splash-fill"></div>
    </div>
  </div>
</div>

<style is:global>
  .splash {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-cream, #f2ecdf);
    color: var(--color-ink, #0a0a0a);
    pointer-events: auto;
    transition: opacity 520ms ease-out, transform 520ms ease-out;
    will-change: opacity, transform;
  }
  .splash.is-hiding {
    opacity: 0;
    transform: translateY(-2%);
    pointer-events: none;
  }
  .splash-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(24px, 4vw, 44px);
    padding: 0 24px;
  }
  .splash-letters {
    font-size: clamp(4rem, 14vw, 12rem);
    line-height: 0.82;
    letter-spacing: -0.02em;
    display: inline-flex;
    align-items: baseline;
    opacity: 0;
    transform: translateY(20px);
  }
  .splash.is-ready .splash-letters {
    animation: splashLettersIn 700ms cubic-bezier(0.2, 0.85, 0.25, 1) forwards;
  }
  .splash-prod {
    margin-left: -0.05em;
  }
  .splash-bar {
    position: absolute;
    left: -4%;
    right: -4%;
    top: 52%;
    width: 108%;
    transform: translateY(-50%) scaleX(0);
    transform-origin: left center;
  }
  .splash.is-ready .splash-bar {
    animation: splashBarDraw 760ms cubic-bezier(0.2, 0.85, 0.25, 1) 280ms forwards;
  }
  .splash-track {
    width: clamp(180px, 28vw, 260px);
    height: 3px;
    border-radius: 999px;
    background: color-mix(in oklab, currentColor 14%, transparent);
    overflow: hidden;
    opacity: 0;
  }
  .splash.is-ready .splash-track {
    animation: splashFadeIn 400ms ease-out 220ms forwards;
  }
  .splash-fill {
    width: 100%;
    height: 100%;
    background: currentColor;
    transform: translateX(-100%);
  }
  .splash.is-ready .splash-fill {
    animation: splashProgress 1800ms cubic-bezier(0.3, 0.7, 0.3, 1) 320ms forwards;
  }
  @keyframes splashLettersIn {
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes splashBarDraw {
    to { transform: translateY(-50%) scaleX(1); }
  }
  @keyframes splashFadeIn {
    to { opacity: 1; }
  }
  @keyframes splashProgress {
    from { transform: translateX(-100%); }
    to   { transform: translateX(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .splash-letters, .splash-bar, .splash-track, .splash-fill {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }
  html.splash-active,
  html.splash-active body {
    overflow: hidden;
  }
</style>

<script is:inline>
  (function () {
    const MIN_VISIBLE = 2200;
    const FONT_TIMEOUT = 1500;
    const HARD_CAP = 6000;
    const SESSION_KEY = 'resprod_splash_seen';

    try {
      if (sessionStorage.getItem(SESSION_KEY)) {
        const el = document.getElementById('splash');
        if (el) el.remove();
        return;
      }
    } catch (_) {}

    document.documentElement.classList.add('splash-active');
    const splash = document.getElementById('splash');
    if (!splash) return;

    const hide = () => {
      const el = document.getElementById('splash');
      if (!el) return;
      el.classList.add('is-hiding');
      document.documentElement.classList.remove('splash-active');
      try { sessionStorage.setItem(SESSION_KEY, '1'); } catch (_) {}
      setTimeout(() => el.remove(), 600);
    };

    const fontsReady = new Promise((resolve) => {
      let done = false;
      const finish = () => { if (!done) { done = true; resolve(); } };
      if (document.fonts && typeof document.fonts.load === 'function') {
        Promise.all([
          document.fonts.load('1em Boldonse').catch(() => null),
          document.fonts.ready.catch(() => null),
        ]).then(finish);
      } else {
        finish();
      }
      setTimeout(finish, FONT_TIMEOUT);
    });

    let startVisible = 0;
    fontsReady.then(() => {
      splash.classList.add('is-ready');
      startVisible = performance.now();

      const scheduleHide = () => {
        const elapsed = performance.now() - startVisible;
        setTimeout(hide, Math.max(0, MIN_VISIBLE - elapsed));
      };
      if (document.readyState === 'complete') scheduleHide();
      else window.addEventListener('load', scheduleHide, { once: true });
    });

    setTimeout(() => {
      if (document.getElementById('splash')) hide();
    }, HARD_CAP);
  })();
</script>

---
import { services } from '../data/services';
import { site } from '../config/site';

const toneBg: Record<string, string> = {
  lime: 'bg-lime',
  violet: 'bg-violet',
  cream: 'bg-cream-warm',
};
---

<section id="services" class="relative px-6 py-16 md:px-10 md:py-24">
  <div class="mx-auto max-w-[1400px]">
    <div class="mb-10 flex flex-col gap-4 md:mb-14 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="label text-ink/60">06 направлений</p>
        <h2 class="mt-3 font-display text-5xl leading-[0.95] md:text-7xl">
          Что мы умеем снимать
        </h2>
      </div>
      <p class="max-w-md text-sm text-ink/70 md:text-base">
        От 15-секундных Reels до многокамерных прямых трансляций на 8 часов.
        Финальный бюджет и сроки считаем под задачу.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
      {services.map((service) => (
        <article
          role="button"
          tabindex="0"
          data-lead-trigger
          data-lead-service={service.title}
          class={`group relative flex cursor-pointer flex-col rounded-[28px] border border-ink p-6 transition-transform duration-300 hover:-translate-y-1 focus:outline-none focus-visible:ring-2 focus-visible:ring-ink md:p-7 ${toneBg[service.tone]}`}
        >
          <div class="flex items-start justify-between">
            <span class="label text-ink/70">№ {service.number}</span>
            <svg
              viewBox="0 0 24 24"
              class="h-6 w-6 text-ink transition-transform duration-300 group-hover:rotate-45"
              aria-hidden="true"
            >
              <path
                d="M6 6h12v12M18 6 6 18"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                fill="none"
              />
            </svg>
          </div>

          <h3 class="mt-6 font-display text-2xl leading-tight md:text-3xl">
            {service.title}
          </h3>
          <p class="mt-3 text-sm text-ink/80 md:text-base">
            {service.tagline}
          </p>

          <ul class="mt-5 space-y-1.5 text-sm text-ink/75">
            {service.includes.map((item) => (
              <li class="flex gap-2">
                <span class="text-ink/50">·</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>

          <div class="mt-6 flex items-center justify-end border-t border-ink/30 pt-4">
            <span class="label text-ink/70">
              {service.durationWeeks}
              {service.durationWeeks.match(/^\d/) ? ' нед.' : ''}
            </span>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-10 flex flex-wrap items-center justify-between gap-4 rounded-[28px] border border-ink bg-ink p-6 text-cream md:p-8">
      <p class="font-display text-2xl leading-tight md:text-3xl">
        Нужен нестандартный формат?
      </p>
      <button type="button" data-lead-trigger class="btn-lime">
        Оставить заявку
      </button>
    </div>
  </div>
</section>
